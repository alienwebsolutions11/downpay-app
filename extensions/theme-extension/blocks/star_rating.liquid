<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <label class="options_purchase_radio_btn">
      <input type="radio"
        onchange="checkSelling(this);"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>

    <label class="options_purchase_radio_btn">
      <input type="radio"
      onchange="checkSelling(this);"
             name="selling_plan_option"
             value=""
             data-selling-plan
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}

<script>

function checkSelling(radio){
var check_radio = radio.getAttribute("value");
       document.querySelectorAll("[action='/cart/add']").forEach(function(form){
    var check_exist = form.querySelector(".custom_selling");
           var input = document.createElement('input');
input.type = 'hidden';
input.name = 'selling_plan';
           input.className="custom_selling";
input.value = check_radio;

form.appendChild(input);
                    if(check_exist == undefined){
                    form.append(input);  
                    }
                else{
                    check_exist.value = check_radio;
                        }
    });
     
}





(function () {

  function getForm() {
    return document.querySelector('form[action="/cart/add"]');
  }

  function updateSellingPlan(value) {
    const form = getForm();
    if (!form) return;

  
    const existing = form.querySelector('input[name="selling_plan"]');
    if (existing) existing.remove();

    if (value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = value;

      form.appendChild(input);

      console.log('selling_plan added:', value);
    } else {
      console.log(' Pay full selected (no selling_plan)');
    }
  }

  //  RADIO CHANGE

  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    updateSellingPlan(e.target.value);
  });

  // DEFAULT (on page load)

  function initDefault() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    if (checked) {
      updateSellingPlan(checked.value);
    }
  }
// ADD THIS BELOW your script
const originalFetch = window.fetch;

window.fetch = function (url, options) {

  if (url.includes('/cart/add') && options?.body instanceof FormData) {

    const hidden = document.querySelector('input[name="selling_plan"]');

    if (hidden && hidden.value) {
      options.body.set('selling_plan', hidden.value);
      console.log(' selling_plan injected into request:', hidden.value);
    }
  }

  return originalFetch.apply(this, arguments);
};
  document.addEventListener('DOMContentLoaded', initDefault);
  document.addEventListener('shopify:section:load', initDefault);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}