<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  let selectedPlan = '';

  // track radio change
  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    selectedPlan = e.target.value;
    console.log('✅ Selected plan:', selectedPlan);
  });

  // intercept Shopify AJAX request
  const originalFetch = window.fetch;

  window.fetch = function (url, options) {

    if (url.includes('/cart/add') && options?.body) {

      try {
        let body;

        if (options.body instanceof FormData) {
          body = options.body;

          if (selectedPlan) {
            body.set('selling_plan', selectedPlan);
          } else {
            body.delete('selling_plan');
          }

          console.log('🚀 Injected selling_plan into FormData:', selectedPlan);
        }

        if (typeof options.body === 'string') {
          const params = new URLSearchParams(options.body);

          if (selectedPlan) {
            params.set('selling_plan', selectedPlan);
          } else {
            params.delete('selling_plan');
          }

          options.body = params.toString();

          console.log('🚀 Injected selling_plan into request string:', selectedPlan);
        }

      } catch (err) {
        console.log('Error injecting selling_plan', err);
      }
    }

    return originalFetch(url, options);
  };

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}