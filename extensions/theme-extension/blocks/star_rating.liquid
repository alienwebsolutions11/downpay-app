<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% for sp in sp_group.selling_plans %}
      {% assign first_plan = sp %}
      {% break %}
    {% endfor %}
    {% if first_plan %}{% break %}{% endif %}
  {% endfor %}

  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input 
        type="radio"
        name="selling_plan_option"
        value="{{ first_plan.id }}"
        data-selling-plan
      >
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getSelectedSellingPlan() {
    const el = document.querySelector('[data-selling-plan]:checked');
    return el ? el.value : '';
  }

  /* =====================================
     🔥 1. HANDLE DAWN / MODERN THEMES
     (product-form.js based themes)
  ===================================== */
  document.addEventListener('product:submit', function (event) {

    try {
      const sp = getSelectedSellingPlan();
      if (!sp) return;

      const formData = event.detail?.formData;

      if (formData) {
        formData.set('selling_plan', sp);
        console.log('✅ selling_plan added (product:submit)', sp);
      }

    } catch (e) {
      console.error('Error in product:submit', e);
    }

  });


  /* =====================================
     🔥 2. FALLBACK (NON-DAWN THEMES)
  ===================================== */
  function attachFallback() {

    const forms = document.querySelectorAll('form[action*="/cart/add"]');

    forms.forEach(form => {

      if (form.dataset.spBound) return;
      form.dataset.spBound = "true";

      form.addEventListener('submit', function () {

        const sp = getSelectedSellingPlan();

        let existing = form.querySelector('[name="selling_plan"]');
        if (existing) existing.remove();

        if (sp) {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'selling_plan';
          input.value = sp;
          form.appendChild(input);

          console.log('✅ selling_plan added (fallback form)', sp);
        }

      });

    });
  }


  /* =====================================
     🔁 HANDLE DYNAMIC LOAD (DAWN SECTIONS)
  ===================================== */
  function observeDOM() {

    const observer = new MutationObserver(() => {
      attachFallback();
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });

  }


  function init() {
    attachFallback();
    observeDOM();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}