<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  let selectedPlan = '';

  // track selection
  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    selectedPlan = e.target.value;
    console.log('✅ Selected plan:', selectedPlan);
  });

  // 🔥 CRITICAL: Hook into form BEFORE submission
  document.addEventListener('submit', function (e) {

    const form = e.target;

    if (!form.matches('form[action*="/cart/add"]')) return;

    console.log('🚀 Form submit intercepted');

    // remove old
    form.querySelector('input[name="selling_plan"]')?.remove();

    if (selectedPlan) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = selectedPlan;

      form.appendChild(input);

      console.log('✅ selling_plan appended BEFORE submit:', selectedPlan);
    }

  }, true); // ✅ capture phase = VERY IMPORTANT

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}