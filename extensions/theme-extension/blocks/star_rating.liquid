<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getSelectedSellingPlan() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    return checked ? checked.value : '';
  }

  // ✅ ADD HIDDEN INPUT ON CHANGE (FOR NORMAL FORMS)
  function handleChangeEvent() {
    document.addEventListener('change', function (e) {
      if (!e.target.matches('[data-selling-plan]')) return;

      const form = document.querySelector('product-form form') 
                || document.querySelector('form[action*="/cart/add"]');

      if (!form) return;

      // remove old
      form.querySelector('input[name="selling_plan"]')?.remove();

      // add new
      if (e.target.value) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = e.target.value;

        form.appendChild(input);
        console.log('✅ Hidden input added:', input.value);
      } else {
        console.log('🧹 Pay full selected → no selling_plan');
      }
    });
  }

  // ✅ FETCH PATCH (FOR DAWN AJAX)
  function patchFetch() {
    if (window.__ultimateSPPatched) return;
    window.__ultimateSPPatched = true;

    const originalFetch = window.fetch;

    window.fetch = async function (url, options = {}) {

      if (typeof url === 'string' && url.includes('/cart/add')) {

        let sp = getSelectedSellingPlan();

        if (!sp) return originalFetch.apply(this, arguments);

        try {
          if (options.body instanceof FormData) {
            options.body.set('selling_plan', sp);
          }

          else if (typeof options.body === 'string') {
            let body;

            try {
              body = JSON.parse(options.body);
            } catch {
              return originalFetch.apply(this, arguments);
            }

            if (body.items && Array.isArray(body.items)) {
              body.items.forEach(item => {
                item.selling_plan = sp;
              });
            } else {
              body.selling_plan = sp;
            }

            options.body = JSON.stringify(body);
          }

        } catch (e) {
          console.log('SP ERROR:', e);
        }
      }

      return originalFetch.apply(this, arguments);
    };
  }

  // ✅ XHR PATCH (BACKUP)
  function patchXHR() {
    if (window.__ultimateXHRPatched) return;
    window.__ultimateXHRPatched = true;

    const originalOpen = XMLHttpRequest.prototype.open;
    const originalSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function(method, url) {
      this._url = url;
      return originalOpen.apply(this, arguments);
    };

    XMLHttpRequest.prototype.send = function(body) {

      if (this._url && this._url.includes('/cart/add')) {

        let sp = getSelectedSellingPlan();

        if (sp && body instanceof FormData) {
          body.set('selling_plan', sp);
        }
      }

      return originalSend.apply(this, arguments);
    };
  }

  function init() {
    patchFetch();
    patchXHR();
    handleChangeEvent();

    console.log("🚀 Selling Plan script initialized");
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}