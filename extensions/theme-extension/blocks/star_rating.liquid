<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>

    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value=""
             data-selling-plan
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}

<script>
(function () {
console.log('jfhdfjdhf');
  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

  function updateSellingPlan(value) {

    const form = getForm();
    if (!form) {
      console.log('❌ Form not found');
      return;
    }

    // remove old
    const existing = form.querySelector('input[name="selling_plan"]');
    if (existing) existing.remove();

    // add new
    if (value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = value;

      form.appendChild(input);

      console.log('✅ selling_plan added:', value);
    } else {
      console.log('❌ selling_plan removed');
    }
  }

  // =========================
  // 🔁 HANDLE RADIO CHANGE
  // =========================
  document.addEventListener('change', function (e) {

    if (!e.target.matches('[data-selling-plan]')) return;

    updateSellingPlan(e.target.value);

  });

  // =========================
  // 🔥 HANDLE DYNAMIC LOAD (KEY FIX)
  // =========================
  function init() {

    const checked = document.querySelector('[data-selling-plan]:checked');

    if (checked) {
      updateSellingPlan(checked.value);
    }
  }

  // run on load
  document.addEventListener('DOMContentLoaded', init);

  // run when Shopify reloads section
  document.addEventListener('shopify:section:load', init);

  // 🔥 EXTRA: watch DOM changes (Dawn replaces form)
  const observer = new MutationObserver(() => {
    init();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

})();
</script>


{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}