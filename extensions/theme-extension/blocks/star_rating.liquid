<style>
.options_purchase_radio_btn {
  display: block;
  margin-bottom: 6px;
}
</style>

<!-- PRODUCT JSON (IMPORTANT) -->
<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}

  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}

    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >

        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">

          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'fixed' %}
            {{ charge.value | money }} deposit
          {% endif %}

        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>

</fieldset>

<script>
(function () {

  function initSellingPlans() {
    const wrapper = document.querySelector('[data-selling-plan-wrapper]');
    if (!wrapper) return;

    const form = document.querySelector('form[action*="/cart/add"]');
    if (!form) return;

    wrapper.addEventListener('change', function (e) {
      if (!e.target.matches('[data-selling-plan]')) return;

      form.querySelector('input[name="selling_plan"]')?.remove();

      if (e.target.value) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = e.target.value;
        form.appendChild(input);
      }
    });

    const checked = wrapper.querySelector('[data-selling-plan]:checked');
    if (checked) checked.dispatchEvent(new Event('change'));
  }

  // 🔥 VARIANT CHANGE HANDLER
  function handleVariantChange(e) {

    if (!e.target.matches('select[name="id"], input[name="id"]')) return;

    const variantId = e.target.value;
    const product = window.productData;

    if (!product) return;

    const variant = product.variants.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    // ✅ Update FULL PRICE
    const priceEl = document.getElementById('full-price');
    if (priceEl) {
      priceEl.innerText = formatMoney(price);
    }

    // ✅ Update DEPOSIT (for percentage)
    const depositEl = document.getElementById('deposit-text');
    if (depositEl) {

      const type = depositEl.dataset.type;
      const value = parseFloat(depositEl.dataset.value);

      if (type === 'percentage') {
        let deposit = (price / 100) * value;
        depositEl.innerText = value + '% deposit ($' + (deposit/100).toFixed(2) + ')';
      }

      if (type === 'fixed') {
        depositEl.innerText = formatMoney(value);
      }
    }
  }

  // 💰 money formatter
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  document.addEventListener('DOMContentLoaded', initSellingPlans);
  document.addEventListener('shopify:section:load', initSellingPlans);

  document.addEventListener('change', handleVariantChange);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "settings": []
}
{% endschema %}