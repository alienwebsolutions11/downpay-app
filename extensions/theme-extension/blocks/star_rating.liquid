<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

 function initSellingPlans() {

  document.addEventListener('change', function (e) {
  if (!e.target.matches('[data-selling-plan]')) return;

  const wrapper = document.querySelector('[data-selling-plan-wrapper]');
  const form = document.querySelector('product-form form') 
            || document.querySelector('form[action*="/cart/add"]');

  if (!wrapper || !form) return;

  form.querySelector('input[name="selling_plan"]')?.remove();

  if (e.target.value) {
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = 'selling_plan';
    input.value = e.target.value;
    form.appendChild(input);
  }
});

  // 🔥 FORCE DEFAULT = PAY FULL
  const defaultRadio = wrapper.querySelector('[data-selling-plan][value=""]');
  if (defaultRadio) {
    defaultRadio.checked = true;

    // remove any existing selling_plan
    form.querySelector('input[name="selling_plan"]')?.remove();
  }
}

  // ✅ Get current variant ID
  function getCurrentVariantId() {
    const form = document.querySelector('form[action*="/cart/add"]');
    if (!form) return null;

    const input = form.querySelector('[name="id"]');
    return input ? input.value : null;
  }

  // ✅ Update UI (price + deposit)
  function updateUI() {

    const variantId = getCurrentVariantId();
    if (!variantId) return;

    const product = window.productData;
    if (!product) return;

    const variant = product.variants.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    // 🔹 Update full price
    const fullPrice = document.getElementById('full-price');
    if (fullPrice) {
      fullPrice.innerText = formatMoney(price);
    }

    // 🔹 Update deposit
    const depositEl = document.getElementById('deposit-text');
    if (depositEl) {

      const type = depositEl.dataset.type;
      const value = parseFloat(depositEl.dataset.value);

      if (type === 'percentage') {
        let deposit = (price * value) / 100;
        depositEl.innerText = value + '% deposit ($' + (deposit/100).toFixed(2) + ')';
      }

      if (type === 'price') {
        depositEl.innerText = formatMoney(value);
      }
    }
  }

  // 💰 money format
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  // 🔥 WATCH variant change (FINAL FIX)
  function watchVariantChange() {
    let lastVariantId = null;

    setInterval(() => {
      const currentId = getCurrentVariantId();

      if (currentId && currentId !== lastVariantId) {
        lastVariantId = currentId;
        updateUI();
      }

    }, 200);
  }

  document.addEventListener('DOMContentLoaded', function(){
    initSellingPlans();
    updateUI();
    watchVariantChange(); 
  });

  document.addEventListener('shopify:section:load', function(){
    initSellingPlans();
    updateUI();
  });

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}