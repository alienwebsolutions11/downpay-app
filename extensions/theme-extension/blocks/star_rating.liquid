<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}
    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >
        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>
</fieldset>

<script>
(function () {

function getActiveForm() {
  // 🔥 get form from Add to Cart button
  const btn = document.querySelector('[name="add"], button[type="submit"]');
  if (btn) return btn.closest('form');

  // fallback
  return document.querySelector('form[action*="/cart/add"]');
}

// ✅ Move block correctly
function moveDepositBlock() {
  const block = document.querySelector('[data-selling-plan-wrapper]');
  const form = getActiveForm();

  if (!block || !form) return;

  if (!block.dataset.moved) {
    form.insertBefore(block, form.firstChild);
    block.dataset.moved = "true";
  }
}

// ✅ Always inject selling plan at submit time
function handleFormSubmit() {
  document.addEventListener('submit', function (e) {

    const form = e.target;

    // only product forms
    if (!form.querySelector('[name="id"]')) return;

    const selected = document.querySelector('[data-selling-plan]:checked');

    // remove old
    form.querySelector('input[name="selling_plan"]')?.remove();

    if (selected && selected.value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = selected.value;

      form.appendChild(input);

      console.log("✅ selling_plan added:", selected.value);
    } else {
      console.log("❌ no selling plan selected");
    }
  });
}

// ✅ UI update (same as yours)
function updateUI() {
  const form = getActiveForm();
  if (!form) return;

  const variantId = form.querySelector('[name="id"]')?.value;
  if (!variantId) return;

  const product = window.productData;
  if (!product) return;

  const variant = product.variants.find(v => v.id == variantId);
  if (!variant) return;

  const price = variant.price;

  const fullPrice = document.getElementById('full-price');
  if (fullPrice) {
    fullPrice.innerText = formatMoney(price);
  }

  const depositEl = document.getElementById('deposit-text');
  if (depositEl) {
    const type = depositEl.dataset.type;
    const value = parseFloat(depositEl.dataset.value);

    if (type === 'percentage') {
      let deposit = (price * value) / 100;
      depositEl.innerText = value + '% deposit ($' + (deposit/100).toFixed(2) + ')';
    }

    if (type === 'price') {
      depositEl.innerText = formatMoney(value);
    }
  }
}

function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}

// ✅ watch variant
function watchVariantChange() {
  let lastId = null;

  setInterval(() => {
    const form = getActiveForm();
    if (!form) return;

    const currentId = form.querySelector('[name="id"]')?.value;

    if (currentId && currentId !== lastId) {
      lastId = currentId;
      updateUI();
    }
  }, 300);
}

// 🚀 INIT
document.addEventListener('DOMContentLoaded', function(){
  moveDepositBlock();
  handleFormSubmit();
  updateUI();
  watchVariantChange();

  setTimeout(moveDepositBlock, 500);
  setTimeout(moveDepositBlock, 1000);
});

document.addEventListener('shopify:section:load', function(){
  moveDepositBlock();
  updateUI();
});

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}