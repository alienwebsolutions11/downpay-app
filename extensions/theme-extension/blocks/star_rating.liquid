<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function updateSellingPlan(selectedValue) {
    const form = document.querySelector('product-form form') 
              || document.querySelector('form[action*="/cart/add"]');

    if (!form) return;

    // remove old input
    form.querySelector('input[name="selling_plan"]')?.remove();

    // add new if exists
    if (selectedValue) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = selectedValue;
      form.appendChild(input);

      console.log('✅ selling_plan set:', selectedValue);
    } else {
      console.log('💰 Pay full selected');
    }
  }

  function bindEvents() {
    if (window.__spBound) return;
    window.__spBound = true;

    // ✅ MAIN FIX (this is what worked in your console)
    document.addEventListener('change', function (e) {
      if (!e.target.matches('[data-selling-plan]')) return;

      updateSellingPlan(e.target.value);
    });

    // ✅ Also handle initial load
    const checked = document.querySelector('[data-selling-plan]:checked');
    if (checked) {
      updateSellingPlan(checked.value);
    }
  }

  function init() {
    bindEvents();
    console.log('✅ Selling Plan WORKING on all themes');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  // ✅ CRITICAL for Dawn / dynamic sections
  document.addEventListener('shopify:section:load', init);

})();
</script>
document.addEventListener('click', function (e) {

  const btn = e.target.closest('button[name="add"]');
  if (!btn) return;

  const sp = document.querySelector('[data-selling-plan]:checked')?.value;

  console.log(' Button click SP:', sp);

}, true);

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}