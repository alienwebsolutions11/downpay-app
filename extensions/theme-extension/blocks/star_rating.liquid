<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}
    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >
        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>
</fieldset>

<script>
(function () {

  function init() {

    document.addEventListener('click', function (e) {

      const btn = e.target.closest('button[name="add"], button[type="submit"]');
      if (!btn) return;

      const form = btn.closest('form[action*="/cart/add"]');
      if (!form) return;

      const checked = form.querySelector('[data-selling-plan]:checked');
      const sellingPlanId = checked ? checked.value : '';

      console.log("👉 selling_plan:", sellingPlanId);

      // remove old
      form.querySelectorAll('input[name="selling_plan"]').forEach(el => el.remove());

      if (sellingPlanId) {
        // add hidden input (fallback for non-AJAX themes)
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = sellingPlanId;
        form.appendChild(input);
      }

      // if no selling plan → normal behavior
      if (!sellingPlanId) return;

      // 🚨 override Dawn
      e.preventDefault();
      e.stopImmediatePropagation();

      const variantId = form.querySelector('[name="id"]')?.value;
      const quantity = parseInt(form.querySelector('[name="quantity"]')?.value || 1);

      if (!variantId) {
        console.error("❌ No variant ID");
        return;
      }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: quantity,
          selling_plan: sellingPlanId
        })
      })
      .then(res => res.json())
      .then(data => {
        console.log("✅ Added with selling_plan:", sellingPlanId);

        // refresh Dawn cart
        document.dispatchEvent(new CustomEvent('cart:added', { detail: data }));
        document.dispatchEvent(new Event('cart:refresh'));
      })
      .catch(err => {
        console.error(err);
        form.submit(); // fallback
      });

    }, true); // VERY IMPORTANT (capture mode)

  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}