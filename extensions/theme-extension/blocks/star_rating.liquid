<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>

    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value=""
             data-selling-plan
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}

<script>
(function () {

  function updateSellingPlan(value) {

    // get product form
    const form = document.querySelector('form[action="/cart/add"]');
    if (!form) return;

    // remove old input
    const existing = form.querySelector('input[name="selling_plan"]');
    if (existing) existing.remove();

    // add new if value exists
    if (value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = value;

      form.appendChild(input);

      console.log('✅ selling_plan added:', value);
    } else {
      console.log(' selling_plan removed (Pay full)');
    }
  }


  document.addEventListener('change', function (e) {

    if (!e.target.matches('[data-selling-plan]')) return;

    updateSellingPlan(e.target.value);

  });

 
  document.addEventListener('DOMContentLoaded', function () {

    const checked = document.querySelector('[data-selling-plan]:checked');

    if (checked) {
      updateSellingPlan(checked.value);
    }

  });

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}