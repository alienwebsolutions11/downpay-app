<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <!-- ✅ Deposit option -->
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan"
             value="{{ first_plan.id }}">
      Deposit
    </label>

    <!-- ✅ Pay full -->
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan"
             value=""
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}

<script>
(function () {

  let selectedPlan = '';

  // ✅ Track radio selection
  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    selectedPlan = e.target.value;
    console.log('✅ Selected plan:', selectedPlan);
  });

  // ================================
  // 🔥 FETCH INTERCEPT (Dawn main)
  // ================================
  const originalFetch = window.fetch;

  window.fetch = async function (...args) {
    let [url, options] = args;

    if (typeof url === 'string' && url.includes('/cart/add')) {

      if (options?.body) {
        try {

          // FormData case
          if (options.body instanceof FormData) {
            if (selectedPlan) {
              options.body.set('selling_plan', selectedPlan);
            } else {
              options.body.delete('selling_plan');
            }

            console.log('🚀 Injected into FormData:', selectedPlan);
          }

          // String case
          if (typeof options.body === 'string') {
            const params = new URLSearchParams(options.body);

            if (selectedPlan) {
              params.set('selling_plan', selectedPlan);
            } else {
              params.delete('selling_plan');
            }

            options.body = params.toString();

            console.log('🚀 Injected into request string:', selectedPlan);
          }

        } catch (err) {
          console.error('Fetch inject error:', err);
        }
      }
    }

    return originalFetch.apply(this, args);
  };

  // ================================
  // 🔥 XHR INTERCEPT (fallback)
  // ================================
  const origOpen = XMLHttpRequest.prototype.open;
  const origSend = XMLHttpRequest.prototype.send;

  XMLHttpRequest.prototype.open = function (method, url) {
    this._url = url;
    return origOpen.apply(this, arguments);
  };

  XMLHttpRequest.prototype.send = function (body) {

    if (this._url && this._url.includes('/cart/add')) {
      try {

        if (body instanceof FormData) {
          if (selectedPlan) {
            body.set('selling_plan', selectedPlan);
          } else {
            body.delete('selling_plan');
          }

          console.log('🚀 XHR FormData injected:', selectedPlan);
        }

        if (typeof body === 'string') {
          const params = new URLSearchParams(body);

          if (selectedPlan) {
            params.set('selling_plan', selectedPlan);
          } else {
            params.delete('selling_plan');
          }

          body = params.toString();

          console.log('🚀 XHR string injected:', selectedPlan);
        }

      } catch (err) {
        console.error('XHR inject error:', err);
      }
    }

    return origSend.call(this, body);
  };

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}