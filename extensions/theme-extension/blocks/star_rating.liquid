<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}
    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >
        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>
</fieldset>

<script>
(function () {

  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

  function moveDepositBlock() {
    const block = document.querySelector('[data-selling-plan-wrapper]');
    const form = getForm();
    if (!block || !form || block.dataset.moved) return;
    form.prepend(block);
    block.dataset.moved = "true";
  }

  function initSellingPlans() {
    const wrapper = document.querySelector('[data-selling-plan-wrapper]');
    if (!wrapper) return;

    wrapper.addEventListener('change', function () {
      forceSellingPlanIntoForm();
    });

    // Default state
    setTimeout(forceSellingPlanIntoForm, 400);
  }

  // Core function - this is the most important part
  function forceSellingPlanIntoForm() {
    const form = getForm();
    if (!form) return;

    const selected = document.querySelector('[data-selling-plan]:checked');
    if (!selected) return;

    // Remove any existing selling_plan input
    form.querySelectorAll('input[name="selling_plan"]').forEach(el => el.remove());

    if (selected.value) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = selected.value;
      form.appendChild(input);
    }
  }

  // Handle both real submit and most AJAX themes
  function handleAddToCart() {
    const forms = document.querySelectorAll('form[action*="/cart/add"]');

    forms.forEach(form => {
      if (form.dataset.depositHandled) return;
      form.dataset.depositHandled = 'true';

      // 1. Real submit
      form.addEventListener('submit', forceSellingPlanIntoForm);

      // 2. Button click (most common in AJAX themes)
      const btn = form.querySelector('button[name="add"], button[type="submit"], [type="submit"]');
      if (btn) {
        btn.addEventListener('click', () => {
          setTimeout(forceSellingPlanIntoForm, 10);   // small delay helps
        });
      }
    });
  }

  function updateUI() {
    const form = getForm();
    if (!form) return;

    const variantId = form.querySelector('[name="id"]')?.value;
    if (!variantId) return;

    const variant = window.productData.variants.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    const fullPriceEl = document.getElementById('full-price');
    if (fullPriceEl) fullPriceEl.textContent = '$' + (price / 100).toFixed(2);

    const depositEl = document.getElementById('deposit-text');
    if (depositEl) {
      const type = depositEl.dataset.type;
      const val = parseFloat(depositEl.dataset.value);

      if (type === 'percentage') {
        const depositAmt = (price * val) / 100;
        depositEl.textContent = `${val}% deposit ($${(depositAmt / 100).toFixed(2)})`;
      } else if (type === 'price') {
        depositEl.textContent = '$' + (val / 100).toFixed(2) + ' deposit';
      }
    }
  }

  function watchVariantChange() {
    let lastId = null;
    setInterval(() => {
      const currentId = getForm()?.querySelector('[name="id"]')?.value;
      if (currentId && currentId !== lastId) {
        lastId = currentId;
        updateUI();
      }
    }, 300);
  }

  // Mutation observer for dynamic AJAX themes
  function observeForms() {
    new MutationObserver(() => {
      handleAddToCart();
    }).observe(document.body, { childList: true, subtree: true });
  }

  // Initialize everything
  function init() {
    moveDepositBlock();
    initSellingPlans();
    handleAddToCart();
    updateUI();
    watchVariantChange();
    observeForms();

    // Extra safety for slow themes
    setTimeout(() => { moveDepositBlock(); handleAddToCart(); forceSellingPlanIntoForm(); }, 800);
    setTimeout(() => { moveDepositBlock(); handleAddToCart(); forceSellingPlanIntoForm(); }, 1500);
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', () => {
    const block = document.querySelector('[data-selling-plan-wrapper]');
    if (block) delete block.dataset.moved;
    init();
  });

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}