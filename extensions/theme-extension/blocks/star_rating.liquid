<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getSelectedSellingPlan() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    return checked ? checked.value : '';
  }

  // ✅ Inject into form (for non-AJAX themes)
  function injectSellingPlanToForm(form) {
    if (!form) return;

    let input = form.querySelector('[name="selling_plan"]');

    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      form.appendChild(input);
    }

    input.value = getSelectedSellingPlan() || '';
  }

  function attachFormListener() {
    document.querySelectorAll('form[action*="/cart/add"]').forEach(form => {

      if (form.dataset.sellingPlanBound) return;
      form.dataset.sellingPlanBound = "true";

      form.addEventListener('submit', function () {
        injectSellingPlanToForm(form);
      });
    });
  }

  // ✅ 🔥 PATCH FETCH (FOR DAWN + AJAX THEMES)
  function patchFetch() {
    if (window.__sellingPlanPatched) return;
    window.__sellingPlanPatched = true;

    const originalFetch = window.fetch;

    window.fetch = async function (url, options = {}) {

      if (typeof url === 'string' && url.includes('/cart/add')) {

        const sp = getSelectedSellingPlan();

        if (sp && options.body) {
          try {
            // JSON request
            if (options.headers && options.headers['Content-Type']?.includes('application/json')) {
              const body = JSON.parse(options.body);
              body.selling_plan = sp;
              options.body = JSON.stringify(body);
            }

            // FormData request
            else if (options.body instanceof FormData) {
              options.body.set('selling_plan', sp);
            }

          } catch (e) {
            console.log('Selling plan error:', e);
          }
        }
      }

      return originalFetch.apply(this, arguments);
    };
  }

  // ✅ Handle dynamic DOM (Dawn re-render)
  const observer = new MutationObserver(() => {
    attachFormListener();
  });

  function init() {
    attachFormListener();
    patchFetch();

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}