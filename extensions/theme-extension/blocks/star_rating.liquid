<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}
    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >
        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>
</fieldset>

<script>
(function () {

  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

  function moveDepositBlock() {
    const block = document.querySelector('[data-selling-plan-wrapper]');
    const form = getForm();
    if (!block || !form || block.dataset.moved) return;
    form.prepend(block);
    block.dataset.moved = "true";
  }

  function getSelectedSellingPlan() {
    const selected = document.querySelector('[data-selling-plan]:checked');
    return selected ? selected.value : '';
  }

  // 1. Normal hidden input method (works on many themes)
  function injectHiddenInput() {
    const form = getForm();
    if (!form) return;

    const sellingPlanId = getSelectedSellingPlan();

    // Remove old ones
    form.querySelectorAll('input[name="selling_plan"]').forEach(el => el.remove());

    if (sellingPlanId) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = sellingPlanId;
      form.appendChild(input);
    }
  }

  // 2. Strong click interceptor - runs late
  function setupClickInterceptor() {
    document.addEventListener('click', function (e) {
      const addButton = e.target.closest('button[name="add"], button[type="submit"], [type="submit"]');
      if (!addButton) return;

      const form = addButton.closest('form[action*="/cart/add"]');
      if (!form) return;

      const sellingPlanId = getSelectedSellingPlan();
      if (!sellingPlanId) return; // full pay → let theme handle normally

      // Inject just before theme processes the click
      injectHiddenInput();

      // Small delay to let theme read the form if it uses FormData
      setTimeout(injectHiddenInput, 5);

    }, true); // capture phase
  }

  function initSellingPlans() {
    const wrapper = document.querySelector('[data-selling-plan-wrapper]');
    if (!wrapper) return;

    wrapper.addEventListener('change', function () {
      injectHiddenInput();
    });

    // Initial
    setTimeout(injectHiddenInput, 300);
  }

  function updateUI() {
    const form = getForm();
    if (!form) return;

    const variantId = form.querySelector('[name="id"]')?.value;
    if (!variantId) return;

    const variant = window.productData.variants.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    const fullPriceEl = document.getElementById('full-price');
    if (fullPriceEl) fullPriceEl.textContent = '$' + (price / 100).toFixed(2);

    const depositEl = document.getElementById('deposit-text');
    if (depositEl) {
      const type = depositEl.dataset.type;
      const val = parseFloat(depositEl.dataset.value);
      if (type === 'percentage') {
        const amt = (price * val) / 100;
        depositEl.textContent = `${val}% deposit ($${(amt / 100).toFixed(2)})`;
      } else if (type === 'price') {
        depositEl.textContent = '$' + (val / 100).toFixed(2) + ' deposit';
      }
    }
  }

  function watchVariantChange() {
    let lastId = null;
    setInterval(() => {
      const current = getForm()?.querySelector('[name="id"]')?.value;
      if (current && current !== lastId) {
        lastId = current;
        updateUI();
      }
    }, 300);
  }

  function init() {
    moveDepositBlock();
    initSellingPlans();
    setupClickInterceptor();
    updateUI();
    watchVariantChange();

    // Extra attempts for slow themes
    setTimeout(() => { moveDepositBlock(); injectHiddenInput(); }, 600);
    setTimeout(() => { moveDepositBlock(); injectHiddenInput(); }, 1200);
    setTimeout(() => { moveDepositBlock(); injectHiddenInput(); }, 2000);
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', () => {
    const block = document.querySelector('[data-selling-plan-wrapper]');
    if (block) delete block.dataset.moved;
    init();
  });

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}