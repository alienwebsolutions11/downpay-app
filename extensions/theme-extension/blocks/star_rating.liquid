<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <!-- ✅ Deposit option -->
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan"
             value="{{ first_plan.id }}">
      Deposit
    </label>

    <!-- ✅ Pay full -->
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan"
             value=""
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}

<script>
(function () {

  let selectedPlan = '';

  // ✅ Track radio selection
  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    selectedPlan = e.target.value;
    console.log('✅ Selected plan:', selectedPlan);
  });

  // ================================
  // 🔥 OVERRIDE FormData (FINAL FIX)
  // ================================
  const OriginalFormData = window.FormData;

  window.FormData = function (form) {
    const fd = new OriginalFormData(form);

    // Only modify product form
    if (form && form.action && form.action.includes('/cart/add')) {

      if (selectedPlan) {
        fd.set('selling_plan', selectedPlan);
      } else {
        fd.delete('selling_plan');
      }

      console.log('🚀 FormData modified:', selectedPlan);
    }

    return fd;
  };

  window.FormData.prototype = OriginalFormData.prototype;

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}