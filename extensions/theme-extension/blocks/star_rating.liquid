<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <!-- ✅ Deposit option -->
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan"
             value="{{ first_plan.id }}">
      Deposit
    </label>

    <!-- ✅ Pay full -->
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan"
             value=""
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}

<script>
(function () {

  let selectedPlan = '';

  // track selection
  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    selectedPlan = e.target.value;
    console.log('✅ Selected plan:', selectedPlan);
  });

  // 🔥 CRITICAL: Hook into form BEFORE submission
  document.addEventListener('submit', function (e) {

    const form = e.target;

    if (!form.matches('form[action*="/cart/add"]')) return;

    console.log('🚀 Form submit intercepted');

    // remove old
    form.querySelector('input[name="selling_plan"]')?.remove();

    if (selectedPlan) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = selectedPlan;

      form.appendChild(input);

      console.log('✅ selling_plan appended BEFORE submit:', selectedPlan);
    }

  }, true); // ✅ capture phase = VERY IMPORTANT

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}