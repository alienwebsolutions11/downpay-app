<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  // ✅ ALWAYS get selected plan (global — safest fallback)
  function getSellingPlan() {
    const el = document.querySelector('[data-selling-plan]:checked');
    return el ? el.value : '';
  }

  // ✅ PATCH FETCH (modern themes like Dawn)
  function patchFetch() {
    if (window.__spFetchPatched) return;
    window.__spFetchPatched = true;

    const originalFetch = window.fetch;

    window.fetch = function (url, options = {}) {

      if (typeof url === 'string' && url.includes('/cart/add')) {

        const sp = getSellingPlan();

        if (sp && options.body) {
          try {
            if (options.body instanceof FormData) {
              options.body.set('selling_plan', sp);
            } else if (typeof options.body === 'string') {
              try {
                const json = JSON.parse(options.body);
                json.selling_plan = sp;
                options.body = JSON.stringify(json);
              } catch {}
            }
          } catch (e) {
            console.log('SP fetch error', e);
          }
        }
      }

      return originalFetch.apply(this, arguments);
    };
  }

  // ✅ PATCH XHR (older / custom themes)
  function patchXHR() {
    if (window.__spXHRPatched) return;
    window.__spXHRPatched = true;

    const originalOpen = XMLHttpRequest.prototype.open;
    const originalSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function(method, url) {
      this._url = url;
      return originalOpen.apply(this, arguments);
    };

    XMLHttpRequest.prototype.send = function(body) {

      if (this._url && this._url.includes('/cart/add')) {

        const sp = getSellingPlan();

        if (sp && body instanceof FormData) {
          body.set('selling_plan', sp);
        }
      }

      return originalSend.apply(this, arguments);
    };
  }

  function init() {
    patchFetch();
    patchXHR();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}