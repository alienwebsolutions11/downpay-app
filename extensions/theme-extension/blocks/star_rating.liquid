<style>
.options_purchase_radio_btn {
  display: block;
  margin-bottom: 6px;
}
</style>

<!-- ✅ Always load product (works on all themes) -->
<script>
window.productData = null;

fetch(window.location.pathname + ".js")
  .then(res => res.json())
  .then(data => {
    window.productData = data;
    console.log("✅ Product loaded:", data);
  });
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}

  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}

    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >

        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>

</fieldset>

<script>
(function () {

// 🔥 UNIVERSAL FORM FINDER
function getForm() {
  return document.querySelector(
    'form[action*="/cart/add"], form[data-product-form], product-form form, .product-form form'
  );
}

// 🔥 MOVE BLOCK ABOVE BUTTON
function moveDepositBlock() {
  const block = document.querySelector('[data-selling-plan-wrapper]');
  const form = getForm();

  if (!block || !form) return;

  if (!block.dataset.moved) {
    form.prepend(block);
    block.dataset.moved = "true";
  }
}

// 🔥 FORCE ADD selling_plan INTO FORM
function injectSellingPlan() {
  const form = getForm();
  const selected = document.querySelector('[data-selling-plan]:checked');

  if (!form || !selected || !selected.value) return;

  form.querySelector('input[name="selling_plan"]')?.remove();

  const input = document.createElement('input');
  input.type = 'hidden';
  input.name = 'selling_plan';
  input.value = selected.value;

  form.appendChild(input);

  console.log("✅ selling_plan injected:", selected.value);
}

// 🔥 ON CHANGE
function initSellingPlans() {
  const wrapper = document.querySelector('[data-selling-plan-wrapper]');
  if (!wrapper) return;

  wrapper.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    injectSellingPlan();
  });
}

// 🔥 HANDLE FORM SUBMIT (MOST IMPORTANT)
function handleFormSubmit() {
  document.addEventListener('submit', function (e) {
    const form = e.target;

    if (!form.matches('form')) return;
    if (!form.querySelector('[name="id"]')) return;

    injectSellingPlan();
  });
}

// 🔥 UPDATE PRICE
function updateUI() {
  const form = getForm();
  if (!form || !window.productData) return;

  const variantId = form.querySelector('[name="id"]')?.value;
  if (!variantId) return;

  const variant = window.productData.variants.find(v => v.id == variantId);
  if (!variant) return;

  const price = variant.price;

  const fullPrice = document.getElementById('full-price');
  if (fullPrice) {
    fullPrice.innerText = formatMoney(price);
  }

  const depositEl = document.getElementById('deposit-text');
  if (depositEl) {
    const type = depositEl.dataset.type;
    const value = parseFloat(depositEl.dataset.value);

    if (type === 'percentage') {
      let deposit = (price * value) / 100;
      depositEl.innerText = value + '% deposit ($' + (deposit/100).toFixed(2) + ')';
    }

    if (type === 'price') {
      depositEl.innerText = formatMoney(value);
    }
  }
}

function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}

// 🔥 WATCH VARIANT CHANGE
function watchVariantChange() {
  let lastId = null;

  setInterval(() => {
    const form = getForm();
    if (!form) return;

    const currentId = form.querySelector('[name="id"]')?.value;

    if (currentId && currentId !== lastId) {
      lastId = currentId;
      updateUI();
    }
  }, 200);
}

// 🔥 WAIT FOR PRODUCT (IMPORTANT)
function waitForProduct() {
  if (!window.productData || !window.productData.variants) {
    setTimeout(waitForProduct, 100);
    return;
  }

  console.log("🔥 Product ready");

  moveDepositBlock();
  initSellingPlans();
  handleFormSubmit();
  updateUI();
  watchVariantChange();

  injectSellingPlan(); // initial
}

// 🚀 INIT
document.addEventListener('DOMContentLoaded', waitForProduct);

document.addEventListener('shopify:section:load', function(){
  moveDepositBlock();
  initSellingPlans();
  updateUI();
});

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}