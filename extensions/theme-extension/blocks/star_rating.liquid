<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% for sp in sp_group.selling_plans %}
      {% assign first_plan = sp %}
      {% break %}
    {% endfor %}
    {% if first_plan %}{% break %}{% endif %}
  {% endfor %}

  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input 
        type="radio"
        name="selling_plan_option"
        value="{{ first_plan.id }}"
        data-selling-plan
      >
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full
  </label>
</fieldset>

<script>
(function () {
  // ✅ STEP 1: ADD HERE
  let CURRENT_SELLING_PLAN = '';
  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

function getSelectedSellingPlan() {
  return CURRENT_SELLING_PLAN;
}
function watchSellingPlanSelection() {
  document.addEventListener('change', function (e) {
    if (e.target.matches('[data-selling-plan]')) {
      CURRENT_SELLING_PLAN = e.target.value;
      console.log('🧠 Stored selling plan:', CURRENT_SELLING_PLAN);
    }
  });
}
function restoreSelection() {
  if (!CURRENT_SELLING_PLAN) return;

  const el = document.querySelector(
    `[data-selling-plan][value="${CURRENT_SELLING_PLAN}"]`
  );

  if (el) {
    el.checked = true;
    console.log('♻️ Restored selling plan');
  }
}
function observeDOM() {
  const observer = new MutationObserver(() => {
    restoreSelection();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
}
  // 🔥 CORE FIX: intercept Dawn fetch
function patchFetch() {
  const originalFetch = window.fetch;

  window.fetch = async function (url, options) {

    if (
      typeof url === 'string' &&
      (url.includes('/cart/add') || url.includes('/cart/add.js')) &&
      options &&
      options.body
    ) {
      try {
        const sp = getSelectedSellingPlan();
        if (!sp) return originalFetch.apply(this, arguments);

        // ✅ JSON BODY
        if (options.headers?.['Content-Type']?.includes('application/json')) {
          let body = JSON.parse(options.body);

          // 🔥 CASE 1: items array (Dawn, Refresh, etc.)
          if (Array.isArray(body.items)) {
            body.items = body.items.map(item => ({
              ...item,
              selling_plan: sp
            }));
            console.log('✅ Injected selling_plan into items[]:', sp);
          }

          // 🔥 CASE 2: direct object
          else {
            body.selling_plan = sp;
            console.log('✅ Injected selling_plan (root):', sp);
          }

          options.body = JSON.stringify(body);
        }

        // ✅ FORM DATA
        else if (options.body instanceof FormData) {
          options.body.set('selling_plan', sp);
          console.log('✅ Injected selling_plan (FormData):', sp);
        }

      } catch (e) {
        console.error('Fetch patch error', e);
      }
    }

    return originalFetch.apply(this, arguments);
  };
}
function patchFormSubmit() {
  document.addEventListener('submit', function (e) {
    const form = e.target;

    if (form.action && form.action.includes('/cart/add')) {
      const sp = getSelectedSellingPlan();
      if (!sp) return;

      let input = form.querySelector('[name="selling_plan"]');

      if (!input) {
        input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        form.appendChild(input);
      }

      input.value = sp;

      console.log('✅ Injected selling_plan via form submit:', sp);
    }
  });
}
  // UI sync (optional but good)
  function updateUI() {
    const form = getForm();
    if (!form) return;

    const variantId = form.querySelector('[name="id"]')?.value;
    if (!variantId) return;

    const variant = window.productData?.variants?.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    const full = document.getElementById('full-price');
    if (full) full.textContent = '$' + (price / 100).toFixed(2);

    const dep = document.getElementById('deposit-text');
    if (dep) {
      const type = dep.dataset.type;
      const val = parseFloat(dep.dataset.value);

      if (type === 'percentage') {
        const amt = (price * val) / 100;
        dep.textContent = `${val}% deposit ($${(amt / 100).toFixed(2)})`;
      } else {
        dep.textContent = '$' + (val / 100).toFixed(2) + ' deposit';
      }
    }
  }

  function watchVariant() {
    let last;
    setInterval(() => {
      const id = getForm()?.querySelector('[name="id"]')?.value;
      if (id && id !== last) {
        last = id;
        updateUI();
      }
    }, 300);
  }

 function init() {
  patchFetch();
  patchFormSubmit();

  watchSellingPlanSelection(); // ✅ NEW
  observeDOM();                // ✅ NEW

  updateUI();
  watchVariant();

  // ✅ set default on load
  const checked = document.querySelector('[data-selling-plan]:checked');
  if (checked) {
    CURRENT_SELLING_PLAN = checked.value;
  }
}

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}