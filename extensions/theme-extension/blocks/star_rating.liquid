<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

{% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}

{% if first_plan %}
  <fieldset class="selling-plan-fieldset">
    <legend>Choose payment option</legend>

    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>

    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value=""
             data-selling-plan
             checked>
      Pay full
    </label>
  </fieldset>
{% endif %}
<script>
(function () {

  let selectedPlan = '';

  // ✅ Track radio
  document.addEventListener('change', function (e) {
    if (!e.target.matches('[data-selling-plan]')) return;

    selectedPlan = e.target.value;
    console.log('✅ Selected plan:', selectedPlan);
  });

  // ✅ Set default
  function setDefault() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    selectedPlan = checked ? checked.value : '';
    console.log('🔁 Default:', selectedPlan);
  }

  document.addEventListener('DOMContentLoaded', setDefault);
  document.addEventListener('shopify:section:load', setDefault);

  // ============================================
  // 🔥 MAIN FIX: PATCH Dawn product-form submit
  // ============================================

  function patchProductForm() {

    const productForms = document.querySelectorAll('product-form');

    productForms.forEach((pf) => {

      if (pf.__patched) return;
      pf.__patched = true;

      const originalSubmit = pf.onSubmitHandler;

      pf.onSubmitHandler = function (evt) {

        console.log('🚀 Dawn submit intercepted');

        const formData = new FormData(this.form);

        if (selectedPlan) {
          formData.set('selling_plan', selectedPlan);
        } else {
          formData.delete('selling_plan');
        }

        console.log('✅ Injected into FormData:', selectedPlan);

        // 🔥 Replace request
        fetch('/cart/add.js', {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
          console.log('✅ Added to cart:', data);

          // optional: trigger cart update
          document.dispatchEvent(new CustomEvent('cart:refresh'));
        })
        .catch(err => console.error(err));

        evt.preventDefault(); // 🚨 STOP Dawn default
      };

    });
  }

  // run multiple times (Dawn reloads DOM)
  document.addEventListener('DOMContentLoaded', patchProductForm);
  document.addEventListener('shopify:section:load', patchProductForm);

})();
</script>
{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}