<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}
    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >
        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>
</fieldset>

<script>
(function () {

  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

  function moveDepositBlock() {
    const block = document.querySelector('[data-selling-plan-wrapper]');
    const form = getForm();
    if (!block || !form || block.dataset.moved) return;
    form.prepend(block);
    block.dataset.moved = "true";
  }

  function getSelectedSellingPlan() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    return checked ? checked.value : '';
  }

  // Force hidden input (for normal themes)
  function forceHiddenInput() {
    const form = getForm();
    if (!form) return;

    const spId = getSelectedSellingPlan();

    form.querySelectorAll('input[name="selling_plan"]').forEach(el => el.remove());

    if (spId) {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      input.value = spId;
      form.appendChild(input);
    }
  }

  // MAIN FIX: Intercept click and do direct AJAX when deposit is selected
  function setupAggressiveInterceptor() {
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('button[name="add"], button[type="submit"], [type="submit"]');
      if (!btn) return;

      const form = btn.closest('form[action*="/cart/add"]');
      if (!form) return;

      const sellingPlanId = getSelectedSellingPlan();

      // If full payment → let the theme handle normally
      if (!sellingPlanId) return;

      // Force hidden input anyway (in case theme uses it)
      forceHiddenInput();

      // Stop the theme from doing its own thing
      e.preventDefault();
      e.stopImmediatePropagation();

      const variantId = form.querySelector('[name="id"]')?.value;
      const qtyEl = form.querySelector('[name="quantity"]');
      const quantity = qtyEl ? parseInt(qtyEl.value) || 1 : 1;

      if (!variantId) return;

      // Direct AJAX call with selling_plan — this bypasses most theme overrides
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: quantity,
          selling_plan: sellingPlanId
        })
      })
      .then(response => response.json())
      .then(data => {
        console.log('✅ Deposit added successfully with selling_plan:', sellingPlanId);

        // Trigger common cart drawer / refresh events so UI updates
        document.dispatchEvent(new CustomEvent('cart:added', { detail: data }));
        document.dispatchEvent(new Event('cart:refresh'));
        document.dispatchEvent(new CustomEvent('product:added', { detail: data }));
      })
      .catch(err => {
        console.error('Deposit add failed:', err);
        // Last resort fallback
        form.submit();
      });

    }, true); // capture: true = runs BEFORE theme listeners
  }

  function initSellingPlans() {
    const wrapper = document.querySelector('[data-selling-plan-wrapper]');
    if (wrapper) {
      wrapper.addEventListener('change', forceHiddenInput);
    }
    setTimeout(forceHiddenInput, 300);
  }

  function updateUI() {
    const form = getForm();
    if (!form) return;

    const variantId = form.querySelector('[name="id"]')?.value;
    if (!variantId) return;

    const variant = window.productData.variants.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    const fullPriceEl = document.getElementById('full-price');
    if (fullPriceEl) fullPriceEl.textContent = '$' + (price / 100).toFixed(2);

    const depositEl = document.getElementById('deposit-text');
    if (depositEl) {
      const type = depositEl.dataset.type;
      const val = parseFloat(depositEl.dataset.value);
      if (type === 'percentage') {
        const amt = (price * val) / 100;
        depositEl.textContent = `${val}% deposit ($${(amt / 100).toFixed(2)})`;
      } else if (type === 'price') {
        depositEl.textContent = '$' + (val / 100).toFixed(2) + ' deposit';
      }
    }
  }

  function watchVariantChange() {
    let lastId = null;
    setInterval(() => {
      const currentId = getForm()?.querySelector('[name="id"]')?.value;
      if (currentId && currentId !== lastId) {
        lastId = currentId;
        updateUI();
      }
    }, 300);
  }

  function init() {
    moveDepositBlock();
    initSellingPlans();
    setupAggressiveInterceptor();
    updateUI();
    watchVariantChange();

    // Extra safety
    setTimeout(() => { moveDepositBlock(); forceHiddenInput(); }, 800);
    setTimeout(() => { moveDepositBlock(); forceHiddenInput(); }, 1800);
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}