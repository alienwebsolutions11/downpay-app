<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getSelectedSellingPlan() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    return checked ? checked.value : '';
  }

  function interceptAddToCart() {
    if (window.__spClickBound) return;
    window.__spClickBound = true;

    document.addEventListener('click', function (e) {

      const btn = e.target.closest('button[name="add"], [type="submit"]');
      if (!btn) return;

      const form = btn.closest('form');
      if (!form) return;

      const sp = getSelectedSellingPlan();

      console.log("🛒 Add to cart clicked. SP:", sp);

      // remove old
      form.querySelector('input[name="selling_plan"]')?.remove();

      // add new
      if (sp) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = sp;

        form.appendChild(input);

        console.log("✅ selling_plan injected:", sp);
      } else {
        console.log("🧹 Pay full (no plan)");
      }

    }, true); // 🔥 use capture (VERY IMPORTANT)
  }

  function init() {
    interceptAddToCart();
    console.log("🚀 SP final fix loaded");
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', init);

})();
</script>
{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}