<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% if first_plan == null %}
      {% for sp in sp_group.selling_plans %}
        {% assign first_plan = sp %}
        {% break %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if first_plan %}
    {% assign charge = first_plan.checkout_charge %}
    {% if charge %}
      <label class="options_purchase_radio_btn">
        <input 
          type="radio"
          name="selling_plan_option"
          value="{{ first_plan.id }}"
          data-selling-plan
        >
        <span id="deposit-text"
          data-type="{{ charge.value_type }}"
          data-value="{{ charge.value }}">
          {% if charge.value_type == 'percentage' %}
            {{ charge.value }}% deposit
          {% elsif charge.value_type == 'price' %}
            {{ charge.value | money }} deposit
          {% endif %}
        </span>
      </label>
    {% endif %}
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full <span id="full-price">{{ product.price | money }}</span>
  </label>
</fieldset>

<script>
(function () {

  let currentSellingPlan = '';

  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

  function moveDepositBlock() {
    const block = document.querySelector('[data-selling-plan-wrapper]');
    const form = getForm();
    if (!block || !form || block.dataset.moved) return;
    form.prepend(block);
    block.dataset.moved = "true";
  }

  function initSellingPlans() {
    const wrapper = document.querySelector('[data-selling-plan-wrapper]');
    if (!wrapper) return;

    wrapper.addEventListener('change', function (e) {
      if (e.target.matches('[data-selling-plan]')) {
        currentSellingPlan = e.target.value;
      }
    });

    // Set initial value
    const checked = wrapper.querySelector('[data-selling-plan]:checked');
    if (checked) currentSellingPlan = checked.value;
  }

  // ==================== MAIN FIX ====================
  function interceptAddToCart() {
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('button[name="add"], button[type="submit"], [type="submit"]');
      if (!btn) return;

      const form = btn.closest('form[action*="/cart/add"]');
      if (!form) return;

      // Get current selected selling plan
      const selected = document.querySelector('[data-selling-plan]:checked');
      const sellingPlanId = selected ? selected.value : '';

      if (!sellingPlanId) return; // full payment - no need to do anything

      // Prevent default theme behavior
      e.preventDefault();
      e.stopImmediatePropagation();

      const variantId = form.querySelector('[name="id"]').value;
      const quantity = form.querySelector('[name="quantity"]') ? parseInt(form.querySelector('[name="quantity"]').value) || 1 : 1;

      // Manually call Shopify AJAX Cart API with selling_plan
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: quantity,
          selling_plan: sellingPlanId
        })
      })
      .then(response => response.json())
      .then(data => {
        // Trigger theme's cart drawer / notification
        if (typeof Shopify !== 'undefined' && Shopify.onItemAdded) {
          Shopify.onItemAdded(data);
        } else {
          // Fallback: dispatch event that most themes listen to
          document.dispatchEvent(new CustomEvent('cart:added', { detail: data }));
          document.dispatchEvent(new Event('cart:refresh'));
        }
        // Optional: show success message
        console.log('Added with deposit selling plan:', sellingPlanId);
      })
      .catch(err => {
        console.error('Deposit add to cart error:', err);
        // Fallback to normal behavior
        form.submit();
      });
    }, true); // Use capture phase to run before theme's listeners
  }

  function updateUI() {
    const form = getForm();
    if (!form) return;

    const variantId = form.querySelector('[name="id"]')?.value;
    if (!variantId) return;

    const variant = window.productData.variants.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    const fullPriceEl = document.getElementById('full-price');
    if (fullPriceEl) fullPriceEl.textContent = '$' + (price / 100).toFixed(2);

    const depositEl = document.getElementById('deposit-text');
    if (depositEl) {
      const type = depositEl.dataset.type;
      const val = parseFloat(depositEl.dataset.value);
      if (type === 'percentage') {
        const amt = (price * val) / 100;
        depositEl.textContent = `${val}% deposit ($${(amt / 100).toFixed(2)})`;
      } else if (type === 'price') {
        depositEl.textContent = '$' + (val / 100).toFixed(2) + ' deposit';
      }
    }
  }

  function watchVariantChange() {
    let lastId = null;
    setInterval(() => {
      const currentId = getForm()?.querySelector('[name="id"]')?.value;
      if (currentId && currentId !== lastId) {
        lastId = currentId;
        updateUI();
      }
    }, 300);
  }

  // Init
  function init() {
    moveDepositBlock();
    initSellingPlans();
    interceptAddToCart();
    updateUI();
    watchVariantChange();

    setTimeout(() => { moveDepositBlock(); }, 800);
    setTimeout(() => { moveDepositBlock(); }, 1500);
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}