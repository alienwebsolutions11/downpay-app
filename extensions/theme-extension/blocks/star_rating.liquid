<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% for sp in sp_group.selling_plans %}
      {% assign first_plan = sp %}
      {% break %}
    {% endfor %}
    {% if first_plan %}{% break %}{% endif %}
  {% endfor %}

  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input 
        type="radio"
        name="selling_plan_option"
        value="{{ first_plan.id }}"
        data-selling-plan
      >
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getSelectedSellingPlan() {
    const el = document.querySelector('[data-selling-plan]:checked');
    return el ? el.value : '';
  }

  /* ===============================
     1️⃣ PATCH FETCH (Dawn, modern themes)
  =============================== */
  const originalFetch = window.fetch;
  window.fetch = async function (url, options) {
    if (
      typeof url === 'string' &&
      url.includes('/cart/add') &&
      options &&
      options.body
    ) {
      try {
        const sp = getSelectedSellingPlan();

        if (!sp) return originalFetch.apply(this, arguments);

        // JSON body
        if (options.headers?.['Content-Type']?.includes('application/json')) {
          let body = JSON.parse(options.body);
          body.selling_plan = sp;
          options.body = JSON.stringify(body);
          console.log('✅ selling_plan added (fetch JSON)', sp);
        }

        // FormData body
        else if (options.body instanceof FormData) {
          options.body.set('selling_plan', sp);
          console.log('✅ selling_plan added (fetch FormData)', sp);
        }

      } catch (e) {
        console.error('Fetch patch error:', e);
      }
    }

    return originalFetch.apply(this, arguments);
  };


  /* ===============================
     2️⃣ PATCH XHR (older/custom themes)
  =============================== */
  const originalOpen = XMLHttpRequest.prototype.open;
  const originalSend = XMLHttpRequest.prototype.send;

  XMLHttpRequest.prototype.open = function (method, url) {
    this._url = url;
    return originalOpen.apply(this, arguments);
  };

  XMLHttpRequest.prototype.send = function (body) {
    try {
      if (this._url && this._url.includes('/cart/add')) {
        const sp = getSelectedSellingPlan();

        if (sp && body instanceof FormData) {
          body.set('selling_plan', sp);
          console.log('✅ selling_plan added (XHR)', sp);
        }
      }
    } catch (e) {
      console.error('XHR patch error:', e);
    }

    return originalSend.apply(this, arguments);
  };


  /* ===============================
     3️⃣ NORMAL FORM SUBMIT (fallback)
  =============================== */
  document.addEventListener('submit', function (e) {
    const form = e.target;

    if (!form || !form.action || !form.action.includes('/cart/add')) return;

    const sp = getSelectedSellingPlan();
    if (!sp) return;

    let input = form.querySelector('[name="selling_plan"]');

    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      form.appendChild(input);
    }

    input.value = sp;

    console.log('✅ selling_plan added (form submit)', sp);
  });


  /* ===============================
     4️⃣ OPTIONAL: VARIANT CHANGE WATCH
  =============================== */
  function watchVariant() {
    let last;

    setInterval(() => {
      const form = document.querySelector('form[action*="/cart/add"]');
      const id = form?.querySelector('[name="id"]')?.value;

      if (id && id !== last) {
        last = id;
        console.log('🔄 Variant changed:', id);
      }
    }, 400);
  }


  function init() {
    watchVariant();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>
{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}