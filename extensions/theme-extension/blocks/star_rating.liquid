<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input
        type="radio"
        name="selling_plan_option"
        value="{{ first_plan.id }}"
        data-selling-plan
      >
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full
  </label>
</fieldset>

<script>
(function () {

  // ✅ Get selected selling plan
  function getSelectedSellingPlan() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    return checked ? checked.value : '';
  }

  // ✅ Inject selling_plan into form
  function injectSellingPlanToForm(form) {
    if (!form) return;

    let input = form.querySelector('[name="selling_plan"]');

    // Create hidden input if not exists
    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      form.appendChild(input);
    }

    // Set value
    input.value = getSelectedSellingPlan() || '';
  }

  // ✅ Attach submit listener to ALL product forms
  function attachFormListener() {
    const forms = document.querySelectorAll('form[action*="/cart/add"]');

    forms.forEach(form => {

      // prevent duplicate binding
      if (form.dataset.sellingPlanBound) return;
      form.dataset.sellingPlanBound = "true";

      form.addEventListener('submit', function () {
        injectSellingPlanToForm(form);
      });
    });
  }

  // ✅ Handle dynamic themes like Dawn
  const observer = new MutationObserver(() => {
    attachFormListener();
  });

  function init() {
    attachFormListener();

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}