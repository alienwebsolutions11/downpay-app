<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  // ✅ Get selected plan
  function getSellingPlan() {
    const checked = document.querySelector('[data-selling-plan]:checked');
    return checked ? checked.value : '';
  }

  // ✅ Attach ONE global handler (no duplicates)
  function bindSellingPlan() {
    if (window.__spFinalBound) return;
    window.__spFinalBound = true;

    // 🔥 Runs BEFORE Shopify handles form (MOST IMPORTANT)
    document.addEventListener('submit', function (e) {

      const form = e.target;

      // only product forms
      if (!form.matches('form[action*="/cart/add"]')) return;

      const sp = getSellingPlan();

      console.log('🛒 Form submit detected. SP:', sp);

      // remove old
      form.querySelector('input[name="selling_plan"]')?.remove();

      // add new
      if (sp) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = sp;

        form.appendChild(input);

        console.log('✅ selling_plan added:', sp);
      } else {
        console.log('🧹 Pay full selected');
      }

    }, true); // 🔥 capture = MUST

  }

  // ✅ Init safely
  function init() {
    bindSellingPlan();
    console.log('✅ Selling Plan FINAL loaded');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('shopify:section:load', init);

})();
</script>document.addEventListener('click', function (e) {

  const btn = e.target.closest('button[name="add"]');
  if (!btn) return;

  const sp = document.querySelector('[data-selling-plan]:checked')?.value;

  console.log('🛒 Button click SP:', sp);

}, true);

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}