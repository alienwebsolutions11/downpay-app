<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  // 🔥 ALWAYS run and re-run (Dawn reload fix)
  function attachSellingPlanHandler() {

    console.log("🚀 Attaching selling plan handler...");

    document.addEventListener('change', function (e) {

      if (!e.target.matches('[data-selling-plan]')) return;

      console.log("🔥 Change detected:", e.target.value);

      // ✅ Always get correct form dynamically
      const form = e.target.closest('form');

      if (!form) {
        console.log("❌ No form found");
        return;
      }

      // 🧹 remove old input
      const oldInput = form.querySelector('input[name="selling_plan"]');
      if (oldInput) oldInput.remove();

      // ✅ add new input
      if (e.target.value) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = e.target.value;

        form.appendChild(input);

        console.log("✅ selling_plan added:", input.value);
      } else {
        console.log("🧹 Pay full selected");
      }

    });
  }

  // 🔁 IMPORTANT: run multiple times safely
  function init() {
    attachSellingPlanHandler();
  }

  // ✅ Run on load
  document.addEventListener('DOMContentLoaded', init);

  // ✅ Run when Dawn reloads section (VERY IMPORTANT)
  document.addEventListener('shopify:section:load', init);

})();
</script>
{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}