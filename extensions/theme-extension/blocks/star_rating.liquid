<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% for sp in sp_group.selling_plans %}
      {% assign first_plan = sp %}
      {% break %}
    {% endfor %}
    {% if first_plan %}{% break %}{% endif %}
  {% endfor %}

  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input 
        type="radio"
        name="selling_plan_option"
        value="{{ first_plan.id }}"
        data-selling-plan
      >
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getForm() {
    return document.querySelector('form[action*="/cart/add"]');
  }

  function getSelectedSellingPlan() {
    const el = document.querySelector('[data-selling-plan]:checked');
    return el ? el.value : '';
  }

  // 🔥 CORE FIX: intercept Dawn fetch
  function patchFetch() {
    const originalFetch = window.fetch;

    window.fetch = async function (url, options) {

      if (
        typeof url === 'string' &&
        url.includes('/cart/add') &&
        options &&
        options.body
      ) {
        try {
          let body;

          // handle JSON body (Dawn default)
          if (options.headers?.['Content-Type']?.includes('application/json')) {
            body = JSON.parse(options.body);

            const sp = getSelectedSellingPlan();
            if (sp) {
              body.selling_plan = sp;
              console.log('✅ Injected selling_plan (JSON):', sp);
            }

            options.body = JSON.stringify(body);
          }

          // handle FormData (fallback themes)
          else if (options.body instanceof FormData) {
            const sp = getSelectedSellingPlan();
            if (sp) {
              options.body.set('selling_plan', sp);
              console.log('✅ Injected selling_plan (FormData):', sp);
            }
          }

        } catch (e) {
          console.error('Fetch patch error', e);
        }
      }

      return originalFetch.apply(this, arguments);
    };
  }

  // UI sync (optional but good)
  function updateUI() {
    const form = getForm();
    if (!form) return;

    const variantId = form.querySelector('[name="id"]')?.value;
    if (!variantId) return;

    const variant = window.productData?.variants?.find(v => v.id == variantId);
    if (!variant) return;

    const price = variant.price;

    const full = document.getElementById('full-price');
    if (full) full.textContent = '$' + (price / 100).toFixed(2);

    const dep = document.getElementById('deposit-text');
    if (dep) {
      const type = dep.dataset.type;
      const val = parseFloat(dep.dataset.value);

      if (type === 'percentage') {
        const amt = (price * val) / 100;
        dep.textContent = `${val}% deposit ($${(amt / 100).toFixed(2)})`;
      } else {
        dep.textContent = '$' + (val / 100).toFixed(2) + ' deposit';
      }
    }
  }

  function watchVariant() {
    let last;
    setInterval(() => {
      const id = getForm()?.querySelector('[name="id"]')?.value;
      if (id && id !== last) {
        last = id;
        updateUI();
      }
    }, 300);
  }

  function init() {
    patchFetch();   // 🔥 IMPORTANT
    updateUI();
    watchVariant();
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}