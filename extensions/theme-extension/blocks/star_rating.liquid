<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Deposit only due at checkout</legend>

  {% assign first_plan = null %}
  {% for sp_group in product.selling_plan_groups %}
    {% for sp in sp_group.selling_plans %}
      {% assign first_plan = sp %}
      {% break %}
    {% endfor %}
    {% if first_plan %}{% break %}{% endif %}
  {% endfor %}

  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input 
        type="radio"
        name="selling_plan_option"
        value="{{ first_plan.id }}"
        data-selling-plan
      >
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input 
      type="radio"
      name="selling_plan_option"
      value=""
      data-selling-plan
      checked
    >
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function getSelectedSellingPlan() {
    const el = document.querySelector('[data-selling-plan]:checked');
    return el ? el.value : '';
  }

  /* -------------------------------
     1️⃣ FORM SUBMIT (All themes)
  --------------------------------*/
  function handleFormSubmit(e) {
    const form = e.target;

    if (!form || !form.action.includes('/cart/add')) return;

    let input = form.querySelector('[name="selling_plan"]');

    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'selling_plan';
      form.appendChild(input);
    }

    input.value = getSelectedSellingPlan();

    console.log('✅ Form submit selling_plan:', input.value);
  }

  /* -------------------------------
     2️⃣ PATCH FETCH (Dawn, OS 2.0)
  --------------------------------*/
  function patchFetch() {
    const originalFetch = window.fetch;

    window.fetch = async function (url, options) {

      if (
        typeof url === 'string' &&
        url.includes('/cart/add') &&
        options &&
        options.body
      ) {
        try {
          const sp = getSelectedSellingPlan();

          // JSON body
          if (options.headers?.['Content-Type']?.includes('application/json')) {
            let body = JSON.parse(options.body);

            if (sp) body.selling_plan = sp;

            options.body = JSON.stringify(body);
            console.log('✅ Fetch JSON selling_plan:', sp);
          }

          // FormData
          else if (options.body instanceof FormData) {
            if (sp) options.body.set('selling_plan', sp);
            console.log('✅ Fetch FormData selling_plan:', sp);
          }

        } catch (err) {
          console.error('Fetch patch error', err);
        }
      }

      return originalFetch.apply(this, arguments);
    };
  }

  /* -------------------------------
     3️⃣ PATCH XHR (Some old themes/apps)
  --------------------------------*/
  function patchXHR() {
    const origOpen = XMLHttpRequest.prototype.open;

    XMLHttpRequest.prototype.open = function (method, url) {
      this._url = url;
      return origOpen.apply(this, arguments);
    };

    const origSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.send = function (body) {

      if (this._url && this._url.includes('/cart/add')) {
        try {
          const sp = getSelectedSellingPlan();

          if (body instanceof FormData) {
            if (sp) body.set('selling_plan', sp);
            console.log('✅ XHR FormData selling_plan:', sp);
          }
        } catch (e) {
          console.error('XHR patch error', e);
        }
      }

      return origSend.apply(this, arguments);
    };
  }

  /* -------------------------------
     INIT
  --------------------------------*/
  function init() {
    document.addEventListener('submit', handleFormSubmit, true);

    patchFetch();
    patchXHR();

    console.log('🔥 Selling plan universal script loaded');
  }

  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('shopify:section:load', init);

})();
</script>

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": []
}
{% endschema %}