<style>
  .options_purchase_radio_btn {
    display: block;
    margin-bottom: 6px;
    cursor: pointer;
  }
</style>

<script>
  window.productData = {{ product | json }};
</script>

<fieldset data-selling-plan-wrapper>
  <legend>Choose payment option</legend>

  {% assign first_plan = product.selling_plan_groups.first.selling_plans.first %}
  
  {% if first_plan %}
    <label class="options_purchase_radio_btn">
      <input type="radio"
             name="selling_plan_option"
             value="{{ first_plan.id }}"
             data-selling-plan>
      Deposit
    </label>
  {% endif %}

  <label class="options_purchase_radio_btn">
    <input type="radio"
           name="selling_plan_option"
           value=""
           data-selling-plan
           checked>
    Pay full
  </label>
</fieldset>

<script>
(function () {

  function updateSellingPlan(value) {
    const forms = document.querySelectorAll('form[action*="/cart/add"]');

    forms.forEach((form) => {
      form.querySelector('input[name="selling_plan"]')?.remove();

      if (value) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'selling_plan';
        input.value = value;
        form.appendChild(input);

        console.log('✅ selling_plan added:', value);
      }
    });
  }

  function bindRadios() {
    const radios = document.querySelectorAll('[data-selling-plan]');

    radios.forEach((radio) => {
      if (radio.__bound) return;

      radio.__bound = true;

      radio.addEventListener('change', function () {
        console.log('🔁 Radio changed:', this.value);
        updateSellingPlan(this.value);
      });
    });

    // run once for default checked
    const checked = document.querySelector('[data-selling-plan]:checked');
    if (checked) {
      updateSellingPlan(checked.value);
    }
  }

  function observeDOM() {
    const observer = new MutationObserver(() => {
      bindRadios();
    });

    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  }

  function init() {
    bindRadios();
    observeDOM();
    console.log('🚀 Selling Plan FIXED (Dawn safe)');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
</script>
document.addEventListener('click', function (e) {

  const btn = e.target.closest('button[name="add"]');
  if (!btn) return;

  const sp = document.querySelector('[data-selling-plan]:checked')?.value;

  console.log(' Button click SP:', sp);

}, true);

{% schema %}
{
  "name": "Deposit Option",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}